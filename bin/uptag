#!/bin/zsh

set -euo pipefail

VERSION="1.0.0"

uptag() {
    local bump_type=""
    local interactive=true

    local RED=$'\033[0;31m' GREEN=$'\033[0;32m' YELLOW=$'\033[1;33m'
    local CYAN=$'\033[0;36m' BOLD=$'\033[1m' DIM=$'\033[2m' NC=$'\033[0m'

    while [[ "$#" -gt 0 ]]; do
        case $1 in
            -p|--patch) bump_type="patch"; interactive=false ;;
            -m|--minor) bump_type="minor"; interactive=false ;;
            -M|--major) bump_type="major"; interactive=false ;;
            -v|--version) echo "uptag $VERSION"; return 0 ;;
            -h|--help)
                echo "Usage: uptag [-p|-m|-M]"
                echo ""
                echo "Options:"
                echo "  -p, --patch     Bump patch version (x.y.Z)"
                echo "  -m, --minor     Bump minor version (x.Y.0)"
                echo "  -M, --major     Bump major version (X.0.0)"
                echo "  -v, --version   Show version"
                echo "  -h, --help      Show this help"
                echo ""
                echo "Without flags, launches interactive mode."
                return 0 ;;
            *) echo "${RED}Unknown option: $1${NC}"; return 1 ;;
        esac
        shift
    done

    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo "${RED}✗ Not inside a git repository${NC}"
        return 1
    fi

    local default_branch
    if git show-ref --verify --quiet refs/heads/main; then
        default_branch="main"
    elif git show-ref --verify --quiet refs/heads/master; then
        default_branch="master"
    else
        echo "${RED}✗ Could not find main or master branch${NC}"
        return 1
    fi

    local latest_tag
    latest_tag=$(git describe --tags --abbrev=0 "$default_branch" 2>/dev/null)
    if [[ -z "$latest_tag" ]]; then
        echo "${RED}✗ No tags found on ${default_branch}${NC}"
        return 1
    fi

    local prefix="" version="$latest_tag"
    if [[ "$version" == v* ]]; then
        prefix="v"
        version="${version#v}"
    fi

    local major minor patch
    IFS='.' read -r major minor patch <<< "$version"
    if [[ -z "$major" || -z "$minor" || -z "$patch" ]]; then
        echo "${RED}✗ Could not parse version from tag: ${latest_tag}${NC}"
        return 1
    fi

    if [[ "$interactive" == true ]]; then
        local options=("patch" "minor" "major")
        local previews=(
            "${prefix}${major}.${minor}.$((patch + 1))"
            "${prefix}${major}.$((minor + 1)).0"
            "${prefix}$((major + 1)).0.0"
        )
        local selected=1

        echo ""
        echo "  ${BOLD}${CYAN}⬆ uptag${NC}  ${DIM}— version bumper${NC}"
        echo "  ${DIM}───────────────────────────${NC}"
        echo "  Current tag: ${YELLOW}${latest_tag}${NC} ${DIM}on ${default_branch}${NC}"
        echo ""

        tput civis
        trap 'tput cnorm; return' INT TERM

        for i in 1 2 3; do
            if [[ $i -eq $selected ]]; then
                echo "  ${GREEN}❯ ${BOLD}${options[$i]}${NC}   ${DIM}→${NC}  ${GREEN}${previews[$i]}${NC}"
            else
                echo "    ${DIM}${options[$i]}   →  ${previews[$i]}${NC}"
            fi
        done

        while true; do
            read -rsk1 key
            case "$key" in
                $'\e')
                    read -rsk2 seq
                    case "$seq" in
                        '[A') selected=$(( (selected - 2 + 3) % 3 + 1 )) ;;
                        '[B') selected=$(( selected % 3 + 1 )) ;;
                    esac
                    printf '\033[3A'
                    for i in 1 2 3; do
                        printf '\033[2K'
                        if [[ $i -eq $selected ]]; then
                            echo "  ${GREEN}❯ ${BOLD}${options[$i]}${NC}   ${DIM}→${NC}  ${GREEN}${previews[$i]}${NC}"
                        else
                            echo "    ${DIM}${options[$i]}   →  ${previews[$i]}${NC}"
                        fi
                    done
                    ;;
                $'\n')
                    bump_type="${options[$selected]}"
                    break
                    ;;
                'q')
                    tput cnorm
                    trap - INT TERM
                    echo ""
                    echo "  ${DIM}Cancelled.${NC}"
                    echo ""
                    return 0
                    ;;
            esac
        done

        tput cnorm
        trap - INT TERM
    fi

    local new_major=$major new_minor=$minor new_patch=$patch
    case $bump_type in
        patch) new_patch=$((patch + 1)) ;;
        minor) new_minor=$((minor + 1)); new_patch=0 ;;
        major) new_major=$((major + 1)); new_minor=0; new_patch=0 ;;
    esac
    local new_tag="${prefix}${new_major}.${new_minor}.${new_patch}"

    if [[ "$interactive" == false ]]; then
        echo ""
        echo "  ${BOLD}${CYAN}⬆ uptag${NC}"
        echo "  ${DIM}───────────────────────────${NC}"
        echo "  Current: ${YELLOW}${latest_tag}${NC} ${DIM}on ${default_branch}${NC}"
    fi

    echo ""
    echo "  ${BOLD}${bump_type}${NC} bump: ${YELLOW}${latest_tag}${NC} → ${GREEN}${new_tag}${NC}"
    echo ""
    printf "  Create and push ${GREEN}${new_tag}${NC}? ${DIM}[y/n]${NC} "
    read -rsk1 confirm
    echo ""

    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo ""
        echo "  ${DIM}Cancelled.${NC}"
        echo ""
        return 0
    fi

    echo ""
    printf "  ${DIM}Creating tag...${NC}"
    local tag_output
    tag_output=$(git tag "$new_tag" 2>&1)
    if [[ $? -ne 0 ]]; then
        printf "\r\033[2K"
        echo "  ${RED}✗ Failed to create tag${NC}"
        [[ -n "$tag_output" ]] && echo "  ${DIM}${tag_output}${NC}"
        return 1
    fi
    printf "\r\033[2K"
    echo "  ${GREEN}✓${NC} Tag ${GREEN}${new_tag}${NC} created"

    printf "  ${DIM}Pushing to origin...${NC}"
    local push_output
    push_output=$(git push origin "$new_tag" 2>&1)
    if [[ $? -ne 0 ]]; then
        printf "\r\033[2K"
        echo "  ${RED}✗ Failed to push tag${NC}"
        [[ -n "$push_output" ]] && echo "  ${DIM}${push_output}${NC}"
        return 1
    fi
    printf "\r\033[2K"
    echo "  ${GREEN}✓${NC} Tag ${GREEN}${new_tag}${NC} pushed to origin"
    echo ""
}

uptag "$@"
